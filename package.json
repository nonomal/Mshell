{
  "name": "mshell",
  "version": "0.2.7",
  "description": "MShell - Windows SSH Client",
  "main": "dist-electron/main.js",
  "author": "MShell Team",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "build:check": "vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "mobile:dev": "vite --config vite.mobile.config.ts --host 127.0.0.1 --port 5174",
    "mobile:build": "vite build --config vite.mobile.config.ts",
    "mobile:typecheck": "vue-tsc --noEmit -p tsconfig.mobile.json",
    "android:add": "npm run mobile:build && cap add android",
    "android:sync": "npm run mobile:build && cap sync android",
    "android:open": "cap open android",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@aws-sdk/client-s3": "^3.983.0",
    "@capacitor/android": "^8.3.3",
    "@capacitor/cli": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@google/generative-ai": "^0.24.1",
    "@novnc/novnc": "^1.6.0",
    "archiver": "^7.0.1",
    "axios": "^1.13.4",
    "bufferutil": "^4.1.0",
    "country-flag-icons": "^1.6.9",
    "electron-updater": "^6.7.3",
    "element-plus": "^2.5.0",
    "geoip-lite": "^1.4.10",
    "marked": "^17.0.1",
    "node-cron": "^4.2.1",
    "openai": "^6.17.0",
    "pinia": "^2.1.7",
    "scrypt-js": "^3.0.1",
    "ssh2": "^1.15.0",
    "ssh2-sftp-client": "^10.0.3",
    "tar": "^7.5.7",
    "unzipper": "^0.12.3",
    "utf-8-validate": "^6.0.6",
    "uuid": "^9.0.1",
    "vue": "^3.4.0",
    "vue-i18n": "^11.2.8",
    "ws": "^8.19.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-search": "^0.13.0",
    "xterm-addon-web-links": "^0.9.0",
    "xterm-addon-webgl": "^0.16.0"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.16.1",
    "@types/archiver": "^7.0.0",
    "@types/jsdom": "^27.0.0",
    "@types/marked": "^5.0.2",
    "@types/node": "^20.10.0",
    "@types/ssh2": "^1.15.0",
    "@types/unzipper": "^0.10.11",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "eslint": "^8.55.0",
    "eslint-plugin-vue": "^9.19.0",
    "fast-check": "^3.15.0",
    "jsdom": "^27.4.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vitest": "^1.0.0",
    "vue-tsc": "^3.2.6",
    "wait-on": "^7.2.0"
  }
}
